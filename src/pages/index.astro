---
import SidebarLayout from '../layouts/SidebarLayout.astro';

const sidebarItems = [
  { label: 'About Me', href: '#about', active: true },
  { label: 'What I Work With', href: '#skills' },
  { label: 'Recent TILs', href: '#recent-tils' },
];

const icons = {
  data: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>',
  code: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  cloud: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>',
  git: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M6 9v12"/></svg>',
};

const cards = [
  {
    id: 'data-engineering',
    title: 'Data Engineering',
    description: 'Airflow, Meltano, ELT pipelines at scale.',
    icon: icons.data,
    details: {
      highlights: [
        'Designed and built scalable ELT pipelines ingesting data from 300+ API integrations at Sequoia Consulting Group',
        'Authored, monitored, and troubleshot Airflow DAGs on AWS MWAA for reliable pipeline execution',
        'Built proactive Airflow DAGs at Astronomer to detect and remediate failed tasks, unhealthy deployments, and metadata DB issues',
        'Contributed custom features to the Meltano open-source project, building Singer taps and targets using Meltano SDK',
      ],
      tech: ['Apache Airflow', 'Meltano', 'Singer', 'AWS MWAA', 'SQL', 'NoSQL'],
    },
  },
  {
    id: 'python-ml',
    title: 'Python & ML',
    description: 'Backend services, ML inference, MLOps.',
    icon: icons.code,
    details: {
      highlights: [
        'Built an ML inference system loading 50+ models for optimal inference at Arisglobal',
        'Built end-to-end MLOps pipeline for model retraining on AWS SageMaker',
        'Implemented Auth0 identity management across Django, Flask, and FastAPI applications',
        'Contributor to CPython, Numba, and OpenSearch-py-ml',
      ],
      tech: ['Python', 'PyTorch', 'AWS SageMaker', 'Django', 'FastAPI', 'Flask'],
    },
  },
  {
    id: 'cloud-infra',
    title: 'Cloud & Infra',
    description: 'AWS, Azure, Kubernetes (CKA, CKAD certified).',
    icon: icons.cloud,
    details: {
      highlights: [
        'Managed AKS clusters running 20+ microservices including ML pipeline deployments at Microsoft',
        'Built and maintained CI/CD pipelines in Azure DevOps using Terraform, Azure PowerShell, and Python',
        'Administered core Azure services: App Service, AKS, Data Factory, Databricks, Data Lake, Cosmos DB, and more',
        'Hold both CKA and CKAD Kubernetes certifications',
      ],
      tech: ['AWS', 'Azure', 'GCP', 'Docker', 'Kubernetes', 'Terraform', 'GitHub Actions'],
    },
  },
  {
    id: 'open-source',
    title: 'Open Source',
    description: 'Apache Airflow Committer. Contributor to CPython, Numba, Meltano.',
    icon: icons.git,
    details: {
      highlights: [
        'Promoted to Apache Airflow Committer through extensive contributions',
        'Delivered a workshop on "First Contributions to Apache Airflow" at Apache Airflow Summit 2025',
        'Reproduce customer bugs and author upstream PRs to fix issues in the Airflow codebase at Astronomer',
        'Active contributor to CPython, Numba, OpenSearch-py-ml, and Meltano',
      ],
      tech: ['Apache Airflow', 'CPython', 'Numba', 'Meltano', 'OpenSearch-py-ml'],
    },
  },
];
---

<SidebarLayout title="Kalyan — About" sidebarItems={sidebarItems}>
  <section id="about">
    <h1>About Me</h1>
    <p class="intro">
      Hi, I'm Kalyan — a software engineer and Apache Airflow Committer with a thing for
      building scalable data pipelines, contributing to open source, and learning in public.
      Currently at Astronomer, making Airflow better for everyone.
    </p>
  </section>

  <section id="skills">
    <h2>What I Work With</h2>
    <div class="grid-2 skills-grid">
      {cards.map(card => (
        <div class="card skill-card" data-card-id={card.id} role="button" tabindex="0">
          <div class="card-icon" set:html={card.icon} />
          <div class="card-title">{card.title}</div>
          <div class="card-desc">{card.description}</div>
        </div>
      ))}
    </div>
  </section>

  <section id="recent-tils">
    <h2>Recent TILs</h2>
    <p class="empty-state">No TIL entries yet. Start writing!</p>
  </section>

  <!-- Overlay -->
  <div class="overlay" id="overlay">
    <div class="overlay-backdrop" id="overlayBackdrop"></div>
    <div class="overlay-panel">
      <button class="overlay-close" id="overlayClose" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <div class="overlay-icon" id="overlayIcon"></div>
      <h2 class="overlay-title" id="overlayTitle"></h2>
      <ul class="overlay-highlights" id="overlayHighlights"></ul>
      <div class="overlay-tech" id="overlayTech"></div>
    </div>
  </div>
</SidebarLayout>

<script define:vars={{ cards }}>
  window.__CARDS__ = cards;
</script>

<script>
  const overlay = document.getElementById('overlay')!;
  const overlayBackdrop = document.getElementById('overlayBackdrop')!;
  const overlayClose = document.getElementById('overlayClose')!;
  const overlayIcon = document.getElementById('overlayIcon')!;
  const overlayTitle = document.getElementById('overlayTitle')!;
  const overlayHighlights = document.getElementById('overlayHighlights')!;
  const overlayTech = document.getElementById('overlayTech')!;

  const cards: any[] = (window as any).__CARDS__;

  function openOverlay(cardId: string) {
    const card = cards.find(c => c.id === cardId);
    if (!card) return;

    overlayIcon.innerHTML = card.icon;
    overlayTitle.textContent = card.title;
    overlayHighlights.innerHTML = card.details.highlights
      .map((h: string) => `<li>${h}</li>`)
      .join('');
    overlayTech.innerHTML = card.details.tech
      .map((t: string) => `<span class="overlay-tag">${t}</span>`)
      .join('');

    overlay.classList.add('visible');
    document.body.style.overflow = 'hidden';
  }

  function closeOverlay() {
    overlay.classList.remove('visible');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.skill-card').forEach(el => {
    el.addEventListener('click', () => openOverlay(el.getAttribute('data-card-id')!));
    el.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') openOverlay(el.getAttribute('data-card-id')!);
    });
  });

  overlayBackdrop.addEventListener('click', closeOverlay);
  overlayClose.addEventListener('click', closeOverlay);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeOverlay();
  });
</script>

<style>
  section {
    margin-bottom: 48px;
  }

  h1 {
    margin-bottom: 32px;
  }

  h2 {
    margin-bottom: 20px;
  }

  .intro {
    font-size: 0.92em;
    line-height: 1.8;
    max-width: 640px;
    color: var(--text-body);
  }

  .skills-grid {
    margin-bottom: 48px;
  }

  .skill-card {
    cursor: pointer;
    outline: none;
  }

  .skill-card:focus-visible {
    border-color: var(--purple);
    box-shadow: 0 0 20px var(--purple-glow), 0 0 4px var(--purple-glow-strong);
  }

  .card-icon {
    color: var(--purple);
    margin-bottom: 16px;
    line-height: 1;
  }

  .card-icon :global(svg) {
    width: 28px;
    height: 28px;
  }

  .card-title {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95em;
    margin-bottom: 8px;
  }

  .card-desc {
    color: var(--text-muted);
    font-size: 0.82em;
    line-height: 1.6;
  }

  .empty-state {
    color: var(--text-dim);
    font-size: 0.85em;
    font-style: italic;
  }

  /* ── Overlay ── */
  .overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }

  .overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .overlay-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .overlay-panel {
    position: relative;
    background: var(--card-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 36px 40px;
    max-width: 560px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.4), 0 0 20px var(--purple-glow);
    transform: translateY(12px);
    transition: transform 0.25s;
  }

  .overlay.visible .overlay-panel {
    transform: translateY(0);
  }

  .overlay-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: 4px;
    transition: color 0.2s;
  }

  .overlay-close:hover {
    color: var(--text-primary);
  }

  .overlay-close :global(svg) {
    width: 20px;
    height: 20px;
  }

  .overlay-icon {
    color: var(--purple);
    margin-bottom: 16px;
  }

  .overlay-icon :global(svg) {
    width: 32px;
    height: 32px;
  }

  .overlay-title {
    font-size: 1.2em;
    margin-bottom: 20px;
  }

  .overlay-highlights {
    list-style: none;
    padding: 0;
    margin-bottom: 24px;
  }

  .overlay-highlights :global(li) {
    position: relative;
    padding-left: 16px;
    margin-bottom: 12px;
    font-size: 0.82em;
    line-height: 1.6;
    color: var(--text-body);
  }

  .overlay-highlights :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--purple);
  }

  .overlay-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .overlay-tech :global(.overlay-tag) {
    display: inline-block;
    padding: 3px 12px;
    border-radius: var(--radius-pill);
    font-size: 0.7em;
    background: var(--purple-bg);
    color: var(--purple);
  }
</style>

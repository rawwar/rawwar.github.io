---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';

const allTopics = await getCollection('want-to-learn');
const topicsJson = JSON.stringify(
  allTopics.map(t => ({
    title: t.data.title,
    description: t.data.description,
    tag: t.data.tag,
  }))
);
---

<BaseLayout title="Someday — Kalyan" fullscreen>
  <div class="space-page" id="spacePage">
    <Navbar />
    <canvas id="space"></canvas>

    <!-- View toggle -->
    <div class="view-toggle" id="viewToggle">
      <button class="toggle-btn active" data-view="stars">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        Stars
      </button>
      <button class="toggle-btn" data-view="cards">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Cards
      </button>
    </div>

    <!-- Floating dots that animate between star positions and card grid -->
    <div class="dots-layer" id="dotsLayer"></div>

    <!-- Card grid overlay (hidden by default) -->
    <div class="cards-layer" id="cardsLayer">
      <div class="cards-grid" id="cardsGrid"></div>
    </div>

    <div class="star-tooltip" id="tooltip">
      <div class="tt-title" id="ttTitle"></div>
      <div class="tt-desc" id="ttDesc"></div>
      <div class="tt-tag" id="ttTag"></div>
    </div>

    <div class="page-label" id="pageLabel">
      <h1>Someday</h1>
      <p>My brain is the black hole. These stars are just waiting for their turn to get sucked in.</p>
    </div>
  </div>

  <script define:vars={{ topicsJson }}>
    window.__TOPICS__ = JSON.parse(topicsJson);
  </script>
  <script is:inline src="/scripts/blackhole.js"></script>
</BaseLayout>

<style>
  .space-page {
    position: relative;
    width: 100vw;
    height: 100vh;
    background: var(--bg-deep);
    overflow: hidden;
  }

  .space-page :global(.navbar) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: linear-gradient(180deg, rgba(10, 10, 20, 0.95) 0%, transparent 100%);
  }

  canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* ── View Toggle ── */
  .view-toggle {
    position: absolute;
    top: 14px;
    right: 160px;
    z-index: 150;
    display: flex;
    background: rgba(38, 38, 56, 0.8);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 14px;
    font-size: 0.72em;
    font-family: var(--font);
    color: var(--text-dim);
    background: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .toggle-btn:hover {
    color: var(--text-body);
  }

  .toggle-btn.active {
    background: var(--purple-bg);
    color: var(--purple);
  }

  .toggle-btn svg {
    width: 14px;
    height: 14px;
  }

  /* ── Floating dots layer (for animation) ── */
  .dots-layer {
    position: absolute;
    inset: 0;
    z-index: 60;
    pointer-events: none;
  }

  .dot {
    position: absolute;
    border-radius: 50%;
    background: #bb92f3;
    box-shadow:
      0 0 16px rgba(187, 146, 243, 0.7),
      0 0 40px rgba(187, 146, 243, 0.4),
      0 0 80px rgba(187, 146, 243, 0.2);
    transition: all 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .dot.to-card {
    border-radius: var(--radius);
    background: var(--card-surface);
    box-shadow:
      0 0 12px rgba(255, 255, 255, 0.15),
      0 0 4px rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  /* ── Cards grid overlay ── */
  .cards-layer {
    position: absolute;
    inset: 0;
    z-index: 70;
    overflow-y: auto;
    padding: 80px 48px 48px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease 0.5s;
  }

  .cards-layer.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .someday-card {
    background: var(--card-surface);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius);
    padding: 22px 24px;
    cursor: default;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-shadow:
      0 0 8px rgba(255, 255, 255, 0.06),
      0 0 2px rgba(255, 255, 255, 0.1);
  }

  .someday-card:hover {
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow:
      0 0 20px rgba(255, 255, 255, 0.12),
      0 0 6px rgba(255, 255, 255, 0.25);
  }

  .someday-card .sc-tag {
    display: inline-block;
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    font-size: 0.7em;
    background: var(--purple-bg);
    color: var(--purple);
    margin-bottom: 10px;
  }

  .someday-card .sc-title {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9em;
    margin-bottom: 6px;
  }

  .someday-card .sc-desc {
    color: var(--text-muted);
    font-size: 0.78em;
    line-height: 1.55;
  }

  /* ── Tooltip ── */
  .star-tooltip {
    position: absolute;
    pointer-events: none;
    z-index: 200;
    background: rgba(26, 26, 46, 0.95);
    border: 1px solid var(--purple);
    border-radius: 10px;
    padding: 14px 18px;
    max-width: 260px;
    box-shadow: 0 0 20px rgba(187, 146, 243, 0.2), 0 4px 20px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 0.2s;
    backdrop-filter: blur(8px);
    font-family: var(--font);
  }

  .star-tooltip.visible {
    opacity: 1;
  }

  .tt-title {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.85em;
    margin-bottom: 6px;
  }

  .tt-desc {
    color: var(--text-body);
    font-size: 0.72em;
    line-height: 1.5;
  }

  .tt-tag {
    display: inline-block;
    margin-top: 8px;
    padding: 2px 8px;
    border-radius: 8px;
    font-size: 0.62em;
    background: var(--purple-bg);
    color: var(--purple);
  }

  /* ── Page label ── */
  .page-label {
    position: absolute;
    bottom: 40px;
    left: 40px;
    z-index: 100;
    transition: opacity 0.3s;
  }

  .page-label.hidden {
    opacity: 0;
  }

  .page-label h1 {
    font-size: 1.4em;
    margin-bottom: 6px;
  }

  .page-label p {
    color: var(--text-dim);
    font-size: 0.72em;
    letter-spacing: 1px;
  }
</style>
